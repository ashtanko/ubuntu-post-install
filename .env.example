# .env.example — copy to .env and fill in your values.
# This file is sourced by all scripts to pre-populate user-specific config.
# No value is required — scripts fall back to interactive prompts or sensible defaults.

# ── Your identity ──────────────────────────────────────────────────────────────
# Used by: git config (base.sh), GPG key generation (gpg.sh), SSH key (ssh.sh)
GIT_NAME="Your Full Name"
GIT_EMAIL="you@example.com"

# ── Git defaults ───────────────────────────────────────────────────────────────
# Used by: system/base.sh
GIT_DEFAULT_BRANCH="main"    # default branch name for new repos (main | master)
GIT_EDITOR="nano"            # commit message editor: nano | vim | code | nvim

# ── Installation paths ─────────────────────────────────────────────────────────
# Used by the respective dev/ scripts. Change if you prefer different locations.
FLUTTER_DIR="$HOME/development"   # where the Flutter SDK repo is cloned
NVM_DIR="$HOME/.nvm"              # NVM installation directory
PYENV_ROOT="$HOME/.pyenv"         # pyenv installation directory
GO_INSTALL_DIR="/usr/local/go"    # Go SDK extraction target (needs sudo)
# JAVA_VERSION="21"               # dev/java.sh — OpenJDK major: 8 | 11 | 17 | 21 | 25 (empty = interactive prompt)

# ── Feature flags ──────────────────────────────────────────────────────────────
INSTALL_OH_MY_ZSH="yes"           # tools/zsh.sh:    install Oh My Zsh? yes | no
INSTALL_DOCKER_DESKTOP="yes"      # dev/docker.sh:   install Docker Desktop GUI? yes | no

# ── Setup log ──────────────────────────────────────────────────────────────────
# SETUP_LOG_FILE="$HOME/ubuntu-setup.log"

# ── Essentials ─────────────────────────────────────────────────────────────────
# Used by essentials/*.sh
SWAP_SIZE_GB=4                       # essentials/swap.sh — swap file size in GB
ENABLE_UFW="yes"                     # essentials/firewall.sh — yes | no
ENABLE_AUTO_UPDATES="yes"            # essentials/auto-updates.sh — yes | no
TZ=""                                # essentials/locale-timezone.sh — auto-detect if empty
LOCALE="en_US.UTF-8"                 # essentials/locale-timezone.sh

# ── IDE / Editor ───────────────────────────────────────────────────────────────
# ide/vscode-extensions.sh — whitespace-separated extension IDs
VSCODE_EXTENSIONS="ms-python.python rust-lang.rust-analyzer dbaeumer.vscode-eslint esbenp.prettier-vscode"
# JETBRAINS_TOOLBOX_DIR="$HOME/.local/share/JetBrains/Toolbox"
# NVIM_INSTALL_DIR="$HOME/.local/share/nvim-stable"

# ── Apps ───────────────────────────────────────────────────────────────────────
# apps/postman.sh — where Postman is extracted (symlinked into ~/.local/bin)
# POSTMAN_INSTALL_DIR="$HOME/.local/share/Postman"

# ── Git / Dev helpers ──────────────────────────────────────────────────────────
ENABLE_GIT_COMMIT_SIGNING="no"       # tools/git-config.sh — flip after running system/gpg.sh

# ── Backup ─────────────────────────────────────────────────────────────────────
# tools/backup-home.sh
BACKUP_DIR="$HOME/backups"
BACKUP_ENCRYPT="no"                  # yes = gpg-encrypt the tarball
# BACKUP_GPG_RECIPIENT=""            # defaults to $GIT_EMAIL

# ── AI ─────────────────────────────────────────────────────────────────────────
# ai/prompt-runner.sh — selects which LLM the `prompt` CLI talks to
PROMPT_BACKEND="ollama"              # ollama | openai | anthropic
# PROMPT_MODEL=""                    # backend-specific default if empty
# OLLAMA_HOST="http://localhost:11434"
OPENAI_API_KEY=""                    # required for -b openai
ANTHROPIC_API_KEY=""                 # required for -b anthropic
# LLAMA_CPP_DIR="$HOME/.local/src/llama.cpp"
