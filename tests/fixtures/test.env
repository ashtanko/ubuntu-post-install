# Canned .env used inside test containers. NO SECRETS.
GIT_NAME="CI Tester"
GIT_EMAIL=ci@example.com
GIT_DEFAULT_BRANCH=main
GIT_EDITOR=nano

# Skip flags for scripts that would fail in container
ENABLE_UFW=no
ENABLE_AUTO_UPDATES=no
INSTALL_OH_MY_ZSH=no
INSTALL_DOCKER_DESKTOP=no
ENABLE_GIT_COMMIT_SIGNING=no

# Constrain installs to known paths
SWAP_SIZE_GB=0
TZ=Etc/UTC
LOCALE=en_US.UTF-8
